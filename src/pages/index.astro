    justify-content: center;
    align-items: center;
  }

  main {
    width: 100%;
    max-width: 400px;
    padding: 2rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  label {
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  select,
  input,
  button {
    padding: 0.75rem;
    font-size: 1rem;
    border: 1px solid #ccc;
    border-radius: 4px;
  }

  button {
    background-color: #0066cc;
    color: white;
    border: none;
    cursor: pointer;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  button:hover {
